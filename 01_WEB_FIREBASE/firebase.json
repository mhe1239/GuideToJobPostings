{
  "hosting": {
    "public": "app",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/askNotice",
        "function": {
          "functionId": "askNotice",
          "region": "asia-northeast3"
        }
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
